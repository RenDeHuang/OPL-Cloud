{
  "schemaVersion": 1,
  "owner": "OPL Ledger",
  "purpose": "Control-plane evidence receipts and task evidence receipt baseline.",
  "state": "current",
  "machineBoundary": "Evidence receipt types, required provenance fields, and query/record API shape.",
  "lifecycle": {
    "type": "long_term_contract",
    "removalCondition": "Replace only with a newer current contract for the same boundary."
  },
  "currentScope": "control-plane evidence receipts and task evidence receipt v1 baseline",
  "receiptTypes": [
    "workspace.created",
    "workspace.access_token_reset",
    "workspace.access_token_deleted",
    "task.evidence.v1"
  ],
  "requiredFields": [
    "id",
    "type",
    "accountId",
    "workspaceId",
    "actor",
    "plan",
    "approval",
    "environment",
    "resourceRefs",
    "billingRefs",
    "inputRefs",
    "executionRefs",
    "outputRefs",
    "reviewResults",
    "createdAt"
  ],
  "workspaceCreateReceipt": {
    "plan": [
      "workspaceName",
      "packageId",
      "computeProfile",
      "storageGb"
    ],
    "approval": "implicit_console_policy",
    "environment": [
      "runtimeProvider",
      "workspaceImage"
    ],
    "resourceRefs": [
      "serverId",
      "dockerId",
      "storageId",
      "storageMountPath",
      "urlTokenMode",
      "tokenStatus"
    ],
    "billingRefs": [
      "compute_hold",
      "storage_hold",
      "storage_attached",
      "workspace_entry_created"
    ],
    "continuation": "open_workspace_url"
  },
  "taskEvidenceReceiptV1": {
    "api": {
      "record": "POST /api/ledger/task-receipts",
      "query": "GET /api/ledger/task-receipts?accountId=<accountId>&workspaceId=<workspaceId>&taskId=<taskId>"
    },
    "requiredFields": [
      "accountId",
      "taskId",
      "plan",
      "approval",
      "environment"
    ],
    "refs": [
      "inputRefs",
      "executionRefs",
      "outputRefs"
    ],
    "review": "reviewResults",
    "continuation": "continue_task",
    "ownershipRule": "workspaceId must belong to accountId when provided",
    "appendOnlyState": "evidenceLedger"
  },
  "nonGoals": [
    "full research task provenance",
    "domain reviewer authority",
    "artifact storage ownership",
    "agent run registry"
  ]
}
